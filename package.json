{
  "name": "sistema",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "make": "electron-forge make"
  },
  "devDependencies": {
    "electron": "^28.2.3",
    "@electron-forge/cli": "^6.4.0",
    "@electron-forge/maker-dmg": "^6.4.0",
    "@electron-forge/maker-zip": "^6.4.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "images/icon"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-dmg",
          "config": {
            "format": "ULFO"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": ["darwin"]
        }
      ]
    }
  }
}
